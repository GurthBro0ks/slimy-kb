#!/usr/bin/env bash
set -euo pipefail

KB_ROOT="/home/slimy/kb"
KB_WIKI="$KB_ROOT/wiki"
KB_RAW="$KB_ROOT/raw"
KB_OUTPUT="$KB_ROOT/output"
VAULT_ROOT="/home/slimy/obsidian/slimyai-vault"
LAST_RESULTS="/tmp/wiki-last-results-${USER}.tsv"
LAST_COMPILE_CANDIDATES="/tmp/wiki-last-compile-candidates-${USER}.tsv"
PROMPT_DIR="$KB_OUTPUT/prompts"
PROMPT_HEADER_FILE="$KB_ROOT/tools/kb-prompt-header.txt"
PROMPT_FOOTER_FILE="$KB_ROOT/tools/kb-prompt-footer.txt"

usage() {
    cat << 'USAGE'
Usage:
  wiki search [--raw|--all] "terms"
  wiki open <number|path>
  wiki status
  wiki daily
  wiki compile-candidates
  wiki open-report latest
  wiki prompt-query "question"
  wiki prompt-compile
  wiki sync
  wiki conflicts
  wiki vault-sync
  wiki vault-ingest
  wiki help

Examples:
  wiki search "trading bot crons"
  wiki search --raw "ssh tunnel"
  wiki open 1
  wiki open architecture/knowledge-base-build-pipeline.md
  wiki status
  wiki daily
  wiki compile-candidates
  wiki open-report latest
  wiki prompt-query "how does the ingest flow work?"
  wiki prompt-compile
  wiki sync
  wiki conflicts
  wiki vault-sync
  wiki vault-ingest

Notes:
  vault-ingest writes a run report to:
  /home/slimy/kb/output/obsidian-ingest-report-YYYYMMDD-HHMMSS.md
USAGE
}

trim() {
    sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//'
}

open_with_pager() {
    local target="$1"
    if command -v bat >/dev/null 2>&1; then
        bat --style=plain --paging=always "$target"
    elif command -v batcat >/dev/null 2>&1; then
        batcat --style=plain --paging=always "$target"
    else
        "${PAGER:-less}" "$target"
    fi
}

latest_match_in_dir() {
    local dir="$1"
    local glob="$2"
    local -a matches=()
    shopt -s nullglob
    matches=("$dir"/$glob)
    shopt -u nullglob
    if [[ ${#matches[@]} -eq 0 ]]; then
        return 1
    fi
    ls -1t "${matches[@]}" 2>/dev/null | head -n 1
}

latest_output_markdown() {
    find "$KB_OUTPUT" -type f -name '*.md' ! -path "$PROMPT_DIR/*" -printf '%T@ %p\n' 2>/dev/null \
        | sort -rn \
        | awk 'NR==1 {sub(/^[^ ]+ /,""); print; exit}'
}

latest_report_path() {
    local candidate=""
    candidate=$(latest_match_in_dir "$KB_OUTPUT" 'obsidian-ingest-report-*.md' || true)
    if [[ -n "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    candidate=$(latest_match_in_dir "$KB_OUTPUT" 'query-*.md' || true)
    if [[ -n "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    candidate=$(latest_output_markdown || true)
    if [[ -n "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi
    return 1
}

github_blob_base() {
    local remote repo branch
    remote=$(git -C "$KB_ROOT" remote get-url origin 2>/dev/null || true)
    if [[ -z "$remote" ]]; then
        return 0
    fi

    repo=""
    if [[ "$remote" =~ ^git@github\.com:(.+)\.git$ ]]; then
        repo="${BASH_REMATCH[1]}"
    elif [[ "$remote" =~ ^https://github\.com/(.+)\.git$ ]]; then
        repo="${BASH_REMATCH[1]}"
    elif [[ "$remote" =~ ^https://github\.com/(.+)$ ]]; then
        repo="${BASH_REMATCH[1]}"
    fi

    if [[ -z "$repo" ]]; then
        return 0
    fi

    branch=$(git -C "$KB_ROOT" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
    if [[ -z "$branch" || "$branch" == "HEAD" ]]; then
        branch="main"
    fi

    printf 'https://github.com/%s/blob/%s' "$repo" "$branch"
}

extract_title() {
    local file="$1"
    local header
    header=$(grep -m1 '^# ' "$file" 2>/dev/null || true)
    if [[ -n "$header" ]]; then
        printf '%s\n' "${header#\# }"
        return
    fi
    basename "$file"
}

extract_category() {
    local file="$1"
    local rel="$2"
    local line fallback

    line=$(grep -m1 '^> Category:' "$file" 2>/dev/null | sed -E 's/^> Category:[[:space:]]*//' | trim || true)
    if [[ -n "$line" ]]; then
        printf '%s\n' "$line"
        return
    fi

    if [[ "$rel" == wiki/*/* ]]; then
        fallback=$(printf '%s\n' "$rel" | cut -d'/' -f2)
        printf '%s\n' "$fallback"
        return
    fi

    if [[ "$rel" == raw/*/* ]]; then
        fallback=$(printf '%s\n' "$rel" | cut -d'/' -f2)
        printf 'raw:%s\n' "$fallback"
        return
    fi

    if [[ "$rel" == output/* ]]; then
        printf 'output\n'
        return
    fi

    printf 'unknown\n'
}

collect_files() {
    local scope="$1"
    case "$scope" in
        wiki)
            find "$KB_WIKI" -type f -name '*.md' ! -name '_*.md' | sort
            ;;
        raw)
            find "$KB_ROOT/raw" -type f -name '*.md' | sort
            ;;
        all)
            {
                find "$KB_WIKI" -type f -name '*.md'
                find "$KB_ROOT/raw" -type f -name '*.md'
                find "$KB_ROOT/output" -type f -name '*.md'
            } | sort -u
            ;;
        *)
            return 1
            ;;
    esac
}

collect_raw_markdown_relpaths() {
    find "$KB_RAW" -type f -name '*.md' -printf '%P\n' | sort | sed -E 's#^#raw/#'
}

collect_wiki_article_files() {
    find "$KB_WIKI" -type f -name '*.md' ! -name '_*.md' | sort
}

collect_compile_candidates() {
    local -A referenced=()
    local wiki_file ref raw_rel
    local -a source_lines=()

    while IFS= read -r wiki_file; do
        mapfile -t source_lines < <(grep -hE '^> Sources:' "$wiki_file" || true)
        if [[ ${#source_lines[@]} -eq 0 ]]; then
            continue
        fi
        while IFS= read -r ref; do
            [[ -n "$ref" ]] || continue
            referenced["$ref"]=1
        done < <(printf '%s\n' "${source_lines[@]}" | grep -hoE 'raw/[A-Za-z0-9._/-]+\.md' || true)
    done < <(collect_wiki_article_files)

    while IFS= read -r raw_rel; do
        [[ -n "$raw_rel" ]] || continue
        if [[ -z "${referenced[$raw_rel]:-}" ]]; then
            printf '%s\n' "$raw_rel"
        fi
    done < <(collect_raw_markdown_relpaths)
}

write_compile_candidates_cache() {
    : > "$LAST_COMPILE_CANDIDATES"
    while IFS= read -r rel; do
        [[ -n "$rel" ]] || continue
        printf '%s\n' "$rel" >> "$LAST_COMPILE_CANDIDATES"
    done
}

latest_compile_signal() {
    local by_compile latest
    by_compile=$(git -C "$KB_ROOT" log --grep='compile' -i -n 1 --date=iso-strict --pretty='format:%h | %ad | %s' 2>/dev/null || true)
    if [[ -n "$by_compile" ]]; then
        printf '%s\n' "$by_compile"
        return
    fi
    latest=$(git -C "$KB_ROOT" log -n 1 --date=iso-strict --pretty='format:%h | %ad | %s' 2>/dev/null || true)
    if [[ -n "$latest" ]]; then
        printf '%s\n' "$latest"
    else
        printf '%s\n' "n/a"
    fi
}

run_search() {
    local scope="wiki"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --raw)
                scope="raw"
                shift
                ;;
            --all)
                scope="all"
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -*)
                echo "Unknown option: $1"
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $# -lt 1 ]]; then
        echo "Usage: wiki search [--raw|--all] \"terms\""
        exit 1
    fi

    local query="$*"
    local blob_base

    bash "$KB_ROOT/tools/kb-sync.sh" pull

    mapfile -t files < <(collect_files "$scope")
    if [[ ${#files[@]} -eq 0 ]]; then
        echo "No files found for scope '$scope'."
        : > "$LAST_RESULTS"
        exit 0
    fi

    declare -A seen=()
    local results=()

    add_result() {
        local rel="$1"
        local title="$2"
        local category="$3"
        if [[ -n "${seen[$rel]:-}" ]]; then
            return
        fi
        seen["$rel"]=1
        results+=("$rel"$'\t'"$title"$'\t'"$category")
    }

    local file rel title category

    for file in "${files[@]}"; do
        [[ -f "$file" ]] || continue
        rel="${file#$KB_ROOT/}"
        title=$(extract_title "$file")
        category=$(extract_category "$file" "$rel")
        if printf '%s\n%s\n' "$rel" "$title" | grep -Fqi -- "$query"; then
            add_result "$rel" "$title" "$category"
        fi
    done

    for file in "${files[@]}"; do
        [[ -f "$file" ]] || continue
        rel="${file#$KB_ROOT/}"
        if [[ -n "${seen[$rel]:-}" ]]; then
            continue
        fi
        if grep -Fqi -- "$query" "$file" 2>/dev/null; then
            title=$(extract_title "$file")
            category=$(extract_category "$file" "$rel")
            add_result "$rel" "$title" "$category"
        fi
    done

    blob_base=$(github_blob_base || true)

    printf '=== Wiki Search ===\n'
    printf 'Query: %s\n' "$query"
    printf 'Scope: %s\n\n' "$scope"

    : > "$LAST_RESULTS"

    if [[ ${#results[@]} -eq 0 ]]; then
        echo "No matches found."
        echo "Try: wiki search --all \"$query\""
        exit 0
    fi

    local i=0 line
    for line in "${results[@]}"; do
        i=$((i + 1))
        IFS=$'\t' read -r rel title category <<< "$line"
        printf '[%d] %s | %s | %s\n' "$i" "$title" "$category" "$rel"
        if [[ -n "$blob_base" ]]; then
            printf '    %s/%s\n' "$blob_base" "$rel"
        fi
        printf '%s\n' "$line" >> "$LAST_RESULTS"
    done

    printf '\n%s result(s). Last set saved to %s\n' "${#results[@]}" "$LAST_RESULTS"
}

run_open() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: wiki open <number|path>"
        exit 1
    fi

    local target="$1"
    local rel line

    if [[ "$target" =~ ^[0-9]+$ ]]; then
        if [[ ! -f "$LAST_RESULTS" ]]; then
            echo "No saved results found. Run: wiki search \"terms\""
            exit 1
        fi
        line=$(sed -n "${target}p" "$LAST_RESULTS")
        if [[ -z "$line" ]]; then
            echo "Result $target not found in $LAST_RESULTS"
            exit 1
        fi
        rel=$(printf '%s\n' "$line" | cut -f1)
        target="$KB_ROOT/$rel"
    elif [[ "$target" = /* ]]; then
        :
    elif [[ -f "$KB_ROOT/$target" ]]; then
        target="$KB_ROOT/$target"
    elif [[ -f "$KB_WIKI/$target" ]]; then
        target="$KB_WIKI/$target"
    else
        echo "File not found: $target"
        exit 1
    fi

    if [[ ! -f "$target" ]]; then
        echo "File not found: $target"
        exit 1
    fi

    open_with_pager "$target"
}

run_status() {
    local latest_ingest latest_query latest_compile
    local raw_count wiki_count output_count candidate_count

    latest_ingest=$(latest_match_in_dir "$KB_OUTPUT" 'obsidian-ingest-report-*.md' || true)
    latest_query=$(latest_match_in_dir "$KB_OUTPUT" 'query-*.md' || true)
    latest_compile=$(latest_compile_signal)

    raw_count=$(find "$KB_RAW" -type f -name '*.md' | wc -l | tr -d ' ')
    wiki_count=$(find "$KB_WIKI" -type f -name '*.md' ! -name '_*.md' | wc -l | tr -d ' ')
    output_count=$(find "$KB_OUTPUT" -type f -name '*.md' ! -path "$PROMPT_DIR/*" | wc -l | tr -d ' ')
    candidate_count=$(collect_compile_candidates | wc -l | tr -d ' ')

    echo "=== Wiki Status ==="
    echo "KB Root: $KB_ROOT"
    echo "Vault:   $VAULT_ROOT"
    echo "Latest Ingest Report: ${latest_ingest:-none}"
    echo "Latest Query Output:  ${latest_query:-none}"
    echo "Latest Compile Signal: $latest_compile"
    echo "Raw Markdown Count: $raw_count"
    echo "Wiki Markdown Count (excluding _*.md): $wiki_count"
    echo "Output Markdown Count: $output_count"
    echo "Likely Uncompiled Raw Files: $candidate_count"
    echo "Next: wiki compile-candidates | wiki open-report latest | wiki prompt-compile"
}

stale_article_count() {
    local stale_file="$KB_WIKI/_stale.md"
    local count

    if [[ ! -f "$stale_file" ]]; then
        echo "0"
        return
    fi

    if grep -qi 'no wiki articles are stale' "$stale_file"; then
        echo "0"
        return
    fi

    count=$(grep -Eo '\[[^][]+\]\([^)]*\)' "$stale_file" | wc -l | tr -d ' ')
    if [[ "$count" -gt 0 ]]; then
        echo "$count"
        return
    fi

    count=$(grep -E '^- ' "$stale_file" | wc -l | tr -d ' ')
    echo "$count"
}

last_compile_date() {
    local ts
    ts=$(git -C "$KB_ROOT" log -n 1 --date=iso-strict --pretty='format:%ad' -- wiki 2>/dev/null || true)
    if [[ -n "$ts" ]]; then
        echo "$ts"
    else
        echo "n/a"
    fi
}

last_sync_date() {
    local ts
    ts=$(git -C "$KB_ROOT" log --grep='sync' -i -n 1 --date=iso-strict --pretty='format:%ad' 2>/dev/null || true)
    if [[ -n "$ts" ]]; then
        echo "$ts"
        return
    fi
    ts=$(git -C "$KB_ROOT" log -n 1 --date=iso-strict --pretty='format:%ad' 2>/dev/null || true)
    if [[ -n "$ts" ]]; then
        echo "$ts"
    else
        echo "n/a"
    fi
}

run_daily() {
    local conflict_count inbox_pending uncompiled_count stale_count
    local last_compile last_sync suggestion

    conflict_count=$(find "$KB_ROOT" "$VAULT_ROOT" -type f -iname '*conflict*' 2>/dev/null | wc -l | tr -d ' ')
    inbox_pending=$(find "$VAULT_ROOT/Inbox" -type f 2>/dev/null | wc -l | tr -d ' ')
    uncompiled_count=$(collect_compile_candidates | wc -l | tr -d ' ')
    stale_count=$(stale_article_count)
    last_compile=$(last_compile_date)
    last_sync=$(last_sync_date)

    if [[ "$conflict_count" -gt 0 ]]; then
        suggestion="Resolve conflict files first, then rerun daily."
    elif [[ "$inbox_pending" -gt 0 ]]; then
        suggestion="Run wiki vault-ingest to process Inbox items."
    elif [[ "$uncompiled_count" -gt 0 ]]; then
        suggestion="Run wiki prompt-compile and process uncompiled raw files."
    elif [[ "$stale_count" -gt 0 ]]; then
        suggestion="Refresh stale wiki articles, starting with highest-value pages."
    else
        suggestion="No pending KB maintenance; capture new notes or run wiki prompt-query."
    fi

    echo "=== Wiki Daily ==="
    echo "Conflict Count: $conflict_count"
    echo "Inbox Pending Count: $inbox_pending"
    echo "Uncompiled Raw Count: $uncompiled_count"
    echo "Stale Article Count: $stale_count"
    echo "Last Compile Date: $last_compile"
    echo "Last Sync Date: $last_sync"
    echo "Suggested Next Action: $suggestion"
}

run_compile_candidates() {
    local -a candidates=()
    mapfile -t candidates < <(collect_compile_candidates)
    write_compile_candidates_cache < <(printf '%s\n' "${candidates[@]}")

    echo "=== Compile Candidates ==="
    if [[ ${#candidates[@]} -eq 0 ]]; then
        echo "No unreferenced raw markdown files found."
        echo "Cache: $LAST_COMPILE_CANDIDATES (empty)"
        return
    fi

    local i=0 rel
    for rel in "${candidates[@]}"; do
        i=$((i + 1))
        printf '[%d] %s\n' "$i" "$rel"
    done
    echo
    echo "${#candidates[@]} candidate(s). Cache: $LAST_COMPILE_CANDIDATES"
}

run_open_report() {
    if [[ $# -lt 1 || "$1" != "latest" ]]; then
        echo "Usage: wiki open-report latest"
        exit 1
    fi

    local report
    report=$(latest_report_path || true)
    if [[ -z "$report" ]]; then
        echo "No report markdown found under $KB_OUTPUT."
        exit 1
    fi
    open_with_pager "$report"
}

prompt_header_content() {
    if [[ -f "$PROMPT_HEADER_FILE" ]]; then
        sed -E '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$PROMPT_HEADER_FILE"
    else
        echo "bash /home/slimy/kb/tools/kb-sync.sh pull"
    fi
}

prompt_footer_content() {
    if [[ -f "$PROMPT_FOOTER_FILE" ]]; then
        sed -E '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$PROMPT_FOOTER_FILE"
    else
        echo "bash /home/slimy/kb/tools/kb-sync.sh push"
    fi
}

run_prompt_query() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: wiki prompt-query \"question\""
        exit 1
    fi

    local question="$*"
    local ts out_file
    ts=$(date -u +%Y%m%d-%H%M%S)
    mkdir -p "$PROMPT_DIR"
    out_file="$PROMPT_DIR/query-prompt-$ts.md"

    cat > "$out_file" <<EOF
$(prompt_header_content)

cat /home/slimy/AGENTS.md
cat /home/slimy/claude-progress.md
source /home/slimy/init.sh
cat /home/slimy/kb/KB_AGENTS.md

TASK: KB Query

Question:
$question

Deliverable:
- Write answer to /home/slimy/kb/output/query-$ts.md
- Use wiki-first evidence with file citations
- Include confidence and explicit Wiki Gaps if coverage is incomplete

Constraints:
- Do not modify canonical wiki unless explicitly asked
- Keep output concise, actionable, and source-backed

$(prompt_footer_content)
EOF

    cat "$out_file"
}

run_prompt_compile() {
    local ts out_file
    local -a candidates=()
    mapfile -t candidates < <(collect_compile_candidates)
    ts=$(date -u +%Y%m%d-%H%M%S)
    mkdir -p "$PROMPT_DIR"
    out_file="$PROMPT_DIR/compile-prompt-$ts.md"

    {
        prompt_header_content
        cat <<EOF

cat /home/slimy/AGENTS.md
cat /home/slimy/claude-progress.md
source /home/slimy/init.sh
cat /home/slimy/kb/KB_AGENTS.md

TASK: KB Compile

Goal:
- Compile raw knowledge into canonical wiki updates following KB_AGENTS rules.

Priority Raw Inputs:
EOF
        if [[ ${#candidates[@]} -eq 0 ]]; then
            echo "- No explicit compile candidates detected."
            echo "- Review /home/slimy/kb/raw for freshness and update relevant existing wiki pages."
        else
            local rel
            for rel in "${candidates[@]}"; do
                echo "- /home/slimy/kb/$rel"
            done
        fi
        cat <<EOF

Required updates:
- Update or create wiki articles as needed
- Update /home/slimy/kb/wiki/_index.md
- Update /home/slimy/kb/wiki/_concepts.md if concepts changed
- Preserve source attribution in each article

Validation:
- Confirm compile candidates are fully handled or explicitly deferred with reason

$(prompt_footer_content)
EOF
    } > "$out_file"

    write_compile_candidates_cache < <(printf '%s\n' "${candidates[@]}")
    cat "$out_file"
}

run_conflicts() {
    local -a search_dirs=("$KB_ROOT")
    if [[ -d "$VAULT_ROOT" ]]; then
        search_dirs+=("$VAULT_ROOT")
    fi

    local -a conflicts=()
    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        conflicts+=("$file")
    done < <(find "${search_dirs[@]}" -type f -iname '*conflict*' 2>/dev/null | sort)

    echo "=== KB Conflicts ==="
    if [[ ${#conflicts[@]} -eq 0 ]]; then
        echo "No conflict files found."
        return
    fi

    local file
    for file in "${conflicts[@]}"; do
        local zone rel_path mod_date
        if [[ "$file" == "$KB_ROOT"* ]]; then
            zone="KB"
            rel_path="${file#$KB_ROOT/}"
        else
            zone="Vault"
            rel_path="${file#$VAULT_ROOT/}"
        fi
        mod_date=$(date -r "$file" +%Y-%m-%d 2>/dev/null || echo "unknown")
        printf '%s | %-5s | %s\n' "$mod_date" "$zone" "$rel_path"
    done
    echo
    echo "${#conflicts[@]} conflict file(s) found."
}

run_sync() {
    bash "$KB_ROOT/tools/kb-sync.sh" pull
}

run_vault_sync() {
    bash "$KB_ROOT/tools/kb-obsidian-sync.sh"
}

run_vault_ingest() {
    bash "$KB_ROOT/tools/kb-obsidian-ingest.sh"
}

main() {
    local cmd="${1:-help}"
    case "$cmd" in
        search)
            shift
            run_search "$@"
            ;;
        open)
            shift
            run_open "$@"
            ;;
        status)
            shift
            run_status "$@"
            ;;
        daily)
            shift
            run_daily "$@"
            ;;
        compile-candidates)
            shift
            run_compile_candidates "$@"
            ;;
        open-report)
            shift
            run_open_report "$@"
            ;;
        prompt-query)
            shift
            run_prompt_query "$@"
            ;;
        prompt-compile)
            shift
            run_prompt_compile "$@"
            ;;
        sync)
            shift
            run_sync "$@"
            ;;
        conflicts)
            shift
            run_conflicts "$@"
            ;;
        vault-sync)
            shift
            run_vault_sync "$@"
            ;;
        vault-ingest)
            shift
            run_vault_ingest "$@"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            echo "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac
}

main "$@"
